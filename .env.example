# Strata — 环境变量配置模板
# 复制为 .env 并填入真实值：cp .env.example .env

# ── 大模型（必填） ─────────────────────────────────────────────────────────────
# 推荐使用支持工具调用+视觉的模型，如 qwen3.5-plus 或 qwen-vl-plus
LLM_API_KEY=sk-125340c6211d44cead39302e6bc6acf3
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus

# ── Embedding 模型（必填，可与大模型共用同一 API Key） ─────────────────────────
EMBEDDING_API_KEY=sk-125340c6211d44cead39302e6bc6acf3
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Tavily 搜索（可选，未配置时 search_job 工具不可用） ────────────────────────
# 在 https://app.tavily.com 申请，格式为 tvly-xxx
TAVILY_API_KEY=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

# ── Agent 运行参数（可选，均有默认值） ────────────────────────────────────────
# Agent 工作目录（存放记忆文件、工具输出、画像文件）
AGENT_WORKING_DIR=.job_agent_v2

# 工具输出压缩阈值（字符数，超过则截断并外置文件）
TOOL_RESULT_THRESHOLD=800

# 摘要与回复语言（zh=中文，其他=英文）
AGENT_LANGUAGE=zh
